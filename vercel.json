{
  "version": 2,
  "rewrites": [
    {
      "source": "/pwa",
      "destination": "/apps/attendance-scanner/index.html"
    },
    {
      "source": "/pwa/",
      "destination": "/apps/attendance-scanner/index.html"
    },
    {
      "source": "/pwa/(.*)",
      "destination": "/apps/attendance-scanner/$1"
    },
    {
      "source": "/attendance-scanner",
      "destination": "/apps/attendance-scanner/index.html"
    },
    {
      "source": "/attendance-scanner/",
      "destination": "/apps/attendance-scanner/index.html"
    },
    {
      "source": "/attendance-scanner/(.*)",
      "destination": "/apps/attendance-scanner/$1"
    }
  ],
  "headers": [
    {
      "source": "/apps/attendance-scanner/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/pwa/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/attendance-scanner/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/apps/attendance-scanner/manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "/pwa/manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "/attendance-scanner/manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
